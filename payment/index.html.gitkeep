<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Ask Botz – Payment</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#0a0a14;--card:rgba(255,255,255,0.04);--border:rgba(255,255,255,0.08);--accent:#7c3aed;--green:#10b981;--text:#e2e8f0;--muted:#64748b;--r:16px}
html,body{min-height:100vh;background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;overflow-x:hidden}
.blob{position:fixed;border-radius:50%;filter:blur(80px);opacity:.18;pointer-events:none;z-index:0}
.b1{width:400px;height:400px;background:#7c3aed;top:-100px;left:-100px}
.b2{width:300px;height:300px;background:#06b6d4;top:40%;right:-80px}
.b3{width:250px;height:250px;background:#10b981;bottom:0;left:30%}
.wrap{position:relative;z-index:1;max-width:440px;margin:0 auto;padding:20px 16px 48px}
/* Header */
.hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
.logo-wrap{display:flex;align-items:center;gap:12px}
.logo{width:52px;height:52px;border-radius:14px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,.4);flex-shrink:0}
.brand{font-size:17px;font-weight:800;letter-spacing:1.5px;background:linear-gradient(135deg,#a78bfa,#38bdf8);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.brand-sub{font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-top:1px}
.sec-badge{font-size:12px;color:var(--green);background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.25);padding:6px 12px;border-radius:100px;font-weight:600}
/* Cards */
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:18px;margin-bottom:14px;backdrop-filter:blur(12px)}
.card-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.card-ttl{font-size:13px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:1px}
.v-badge{font-size:12px;color:var(--green);font-weight:600}
.mb12{margin-bottom:12px}
/* Order rows */
.orow{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.05);font-size:14px}
.orow:last-child{border-bottom:none}
.lbl{color:var(--muted)}
.val{font-weight:500}
.mono{font-family:'Courier New',monospace;font-size:12px}
.amt{font-size:26px;font-weight:800;color:var(--green);animation:pulse 2.5s ease-in-out infinite}
@keyframes pulse{0%,100%{text-shadow:0 0 0 rgba(16,185,129,0)}50%{text-shadow:0 0 20px rgba(16,185,129,.5)}}
/* UPI buttons */
.upi-list{display:flex;flex-direction:column;gap:10px}
.upi-btn{display:flex;align-items:center;gap:14px;padding:13px 14px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:12px;color:var(--text);text-decoration:none;font-size:15px;font-weight:500;cursor:pointer;transition:all .18s ease;-webkit-tap-highlight-color:transparent}
.upi-btn:hover,.upi-btn:active{background:rgba(124,58,237,.15);border-color:var(--accent);transform:translateY(-1px)}
.arrow{margin-left:auto;color:var(--muted);font-size:20px;line-height:1}
.app-icon{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden;font-size:11px;font-weight:700}
.ic-gpay{background:#fff}
.ic-phonepe{background:#5f259f;color:#fff}
.ic-paytm{background:#002970;color:#00b9f5}
.ic-amazon{background:#232f3e;color:#ff9900}
.ic-bhim{background:#00529b;color:#fff}
.ic-upi{background:#1e293b;color:#60a5fa}
/* Copy rows */
.crow{display:flex;align-items:center;justify-content:space-between;gap:10px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:12px 14px;margin-bottom:10px}
.crow:last-of-type{margin-bottom:0}
.ci{flex:1;min-width:0}
.clbl{font-size:11px;color:var(--muted);margin-bottom:3px;text-transform:uppercase;letter-spacing:.5px}
.cval{font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-family:'Courier New',monospace}
.cbtn{flex-shrink:0;background:linear-gradient(135deg,#7c3aed,#6d28d9);color:#fff;border:none;padding:8px 16px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;transition:all .18s;font-family:'Inter',sans-serif}
.cbtn:active{opacity:.8;transform:scale(.97)}
.cbtn.copied{background:linear-gradient(135deg,#10b981,#059669)}
.mnote{margin-top:12px;font-size:12px;color:#f59e0b;background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.2);border-radius:8px;padding:10px 12px;text-align:center}
/* After card */
.after-card{text-align:center;background:linear-gradient(135deg,rgba(124,58,237,.12),rgba(6,182,212,.08));border-color:rgba(124,58,237,.25)}
.after-ttl{font-size:16px;font-weight:700;margin-bottom:8px}
.after-desc{font-size:13px;color:var(--muted);margin-bottom:16px;line-height:1.6}
.tg-btn{display:inline-block;background:linear-gradient(135deg,#7c3aed,#06b6d4);color:#fff;text-decoration:none;padding:13px 28px;border-radius:12px;font-weight:700;font-size:14px;box-shadow:0 4px 20px rgba(124,58,237,.35);transition:all .2s}
.tg-btn:active{opacity:.85;transform:scale(.98)}
/* Footer */
.footer{text-align:center;color:var(--muted);font-size:12px;margin-top:8px;line-height:1.8}
.footer a{color:#a78bfa;text-decoration:none}
.footer strong{color:var(--text)}
/* Toast */
.toast{position:fixed;bottom:30px;left:50%;transform:translateX(-50%) translateY(80px);background:rgba(16,185,129,.95);color:#fff;padding:10px 24px;border-radius:100px;font-size:14px;font-weight:600;opacity:0;transition:all .3s cubic-bezier(.34,1.56,.64,1);pointer-events:none;z-index:999;white-space:nowrap}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
/* Skeleton loader */
.loading .val,.loading .amt,.loading .cval{background:rgba(255,255,255,.08);border-radius:6px;color:transparent;animation:shimmer 1.5s infinite}
@keyframes shimmer{0%,100%{opacity:.6}50%{opacity:1}}
@media(max-width:380px){.wrap{padding:14px 12px 32px}.upi-btn{font-size:14px}}
</style>
</head>
<body>

<div class="blob b1"></div>
<div class="blob b2"></div>
<div class="blob b3"></div>

<div class="wrap">

  <!-- Header -->
  <header class="hdr">
    <div class="logo-wrap">
      <div class="logo"><img src="data:image/jpeg;base64,
